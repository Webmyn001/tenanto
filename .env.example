# Copy to .env. Used by docker-compose and the backend dotenv loader.

# ── Core ─────────────────────────────────────────────────────────────
NODE_ENV=development
JWT_SECRET=replace-with-long-random-string
ENCRYPTION_KEY=replace-with-32-byte-base64-or-leave-blank-to-derive-from-jwt
MOCK_THIRD_PARTY=true                # flip to false in production

# ── Paystack ─────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ── Cloudinary ───────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── NIN provider — pick one ──────────────────────────────────────────
NIN_PROVIDER=mock                    # dojah | verifyme | youverify | smileid | mock
DOJAH_APP_ID=
DOJAH_API_KEY=
VERIFYME_API_KEY=
YOUVERIFY_API_KEY=
SMILEID_PARTNER_ID=

# ── Selfie ↔ ID match ────────────────────────────────────────────────
SELFIE_MATCH_PROVIDER=mock           # smileid | rekognition | mock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Maps / distance ──────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
TRANSPORT_PER_KM_NAIRA=250

# ── Email (any SMTP) ─────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Tenanto <noreply@yourdomain.com>

# ── LLM-based chat moderation (optional) ─────────────────────────────
MODERATION_PROVIDER=                 # openai | anthropic | (blank → regex only)
OPENAI_API_KEY=

# ── Observability ────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1
LOG_LEVEL=info

# ── Background jobs ──────────────────────────────────────────────────
JOBS_ENABLED=true                    # set false on web replicas in multi-instance
ESCROW_AUTO_RELEASE_DAYS=7
AUDIT_RETENTION_DAYS=365             # raise to 2555 (7yr) for production AML

# ── Business model knobs ─────────────────────────────────────────────
FEATURE_FEE_NAIRA=5000
