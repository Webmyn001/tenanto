# --- Server ---
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# --- Database ---
MONGO_URI=mongodb://localhost:27017/tenanto

# --- Auth ---
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- Cloudinary (for image/video uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Paystack (escrow / split / installments) ---
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# --- NIN verification provider (e.g. Dojah, VerifyMe, Youverify) ---
NIN_PROVIDER_BASE_URL=
NIN_PROVIDER_API_KEY=

# --- Feature flags ---
# When true, NIN/Paystack calls are mocked. Flip to false in production.
MOCK_THIRD_PARTY=true

# --- NIN provider (multi-provider abstraction) ---
# NIN_PROVIDER=dojah | verifyme | youverify | smileid | mock
NIN_PROVIDER=mock
DOJAH_APP_ID=
DOJAH_API_KEY=
VERIFYME_API_KEY=
YOUVERIFY_API_KEY=
SMILEID_PARTNER_ID=

# --- Selfie ↔ ID match ---
# SELFIE_MATCH_PROVIDER=smileid | rekognition | mock
SELFIE_MATCH_PROVIDER=mock

# --- Liveness detection (separate from match) ---
# LIVENESS_PROVIDER=smileid | rekognition | iproov | mock
LIVENESS_PROVIDER=mock
IPROOV_API_KEY=
IPROOV_SECRET=
AWS_REGION=us-east-1

# --- Cloudinary content moderation ---
# CLOUDINARY_MODERATION=aws_rek | webpurify | google_video_moderation
CLOUDINARY_MODERATION=
# Public URL where Cloudinary should POST moderation results
CLOUDINARY_NOTIFY_URL=

# --- Email (any SMTP provider) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Job runtime ---
# JOBS_ENABLED=false to disable background jobs (e.g. in CI/tests)
JOBS_ENABLED=true
# JOBS_DRIVER=cron | bullmq  (auto-detected if REDIS_URL is set)
JOBS_DRIVER=
JOBS_CONCURRENCY=2
# Set REDIS_URL to opt into BullMQ (multi-instance safe). Otherwise node-cron in-process.
REDIS_URL=
ESCROW_AUTO_RELEASE_DAYS=7
AUDIT_RETENTION_DAYS=365

# --- Observability ---
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1
LOG_LEVEL=info

# --- Encryption (NIN at rest) ---
# Defaults to deriving from JWT_SECRET if blank
ENCRYPTION_KEY=

# --- Optional: Google Maps for distance ---
GOOGLE_MAPS_API_KEY=
TRANSPORT_PER_KM_NAIRA=250

# --- Optional: chat moderation via LLM ---
# MODERATION_PROVIDER=openai
MODERATION_PROVIDER=
OPENAI_API_KEY=

# --- Featured listing fee ---
FEATURE_FEE_NAIRA=5000
